rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // User profile rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
    }

    // Shopkeeper profile rules
    match /shopkeepers/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
    }

    // Dealer profile rules
    match /dealers/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId;
    }

    // Products rules
    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'dealer';
    }

    // Categories rules
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false; // Only admin via console
    }

    // Orders rules
    match /orders/{orderId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.shopkeeper_id || 
         request.auth.uid == resource.data.dealer_id);
      allow create: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_type == 'shopkeeper';
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.shopkeeper_id || 
         request.auth.uid == resource.data.dealer_id);
    }
  }
}
